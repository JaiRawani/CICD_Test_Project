<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="CICD Test Suite" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="org.example.tests"/>
        </packages>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="org.example.tests"/>
        </packages>
    </test>

    <test name="API Tests">
        <packages>
            <package name="org.example.tests"/>
        </packages>
    </test>

</suite>
